# Copy this file to `.env` at the repo root and fill in values.
# Loaded via `from utils import load_env; load_env()`.

# Which model provider to use. One of: foundry | github-copilot | ollama
MODEL_PROVIDER=

# Azure AI Foundry
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=
FOUNDRY_API_KEY=
FOUNDRY_REGION=

# Ollama (local; defaults to http://localhost:11434)
OLLAMA_HOST=
OLLAMA_CHAT_MODEL_ID=llama3.2:3b

# Audio Generation
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=