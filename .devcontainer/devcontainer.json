{
  "name": "AI Podcast Studio Workshop",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "python.analysis.indexing": true,
        "python.analysis.typeCheckingMode": "basic",
        "notebook.defaultKernel": "workshop",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "pip install -e .",
  "postStartCommand": "OLLAMA_CONTEXT_LENGTH=32768 nohup ollama serve > /tmp/ollama.log 2>&1 & sleep 3 && ollama run llama3.2:3b \"pre-warm yourself. just respond with 'yes'. dont think.\" --keepalive 1h",
  "forwardPorts": [8888],
  "portsAttributes": {
    "// 11434": {
      "label": "Ollama",
      "onAutoForward": "silent"
    },
    "8888": {
      "label": "Jupyter",
      "onAutoForward": "notify"
    }
  }
}
