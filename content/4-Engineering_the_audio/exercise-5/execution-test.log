      "text": "Hmm\u2014yeah, that \u201cdeterministic channel\u201d question is the one that makes my therapist brain itch.",
      "delivery": {
        "emotion": "amused",
        "pace": "normal",
        "volume": "slightly_soft",
        "emphasis": [
          "deterministic-channel",
          "agency-itced"
        ],
        "notes": "Let Mara keep the roast momentum, then tee up your stance gently for the next turn."
      },
      "anchor": {
        "phrase": "the channel look so deterministic",
        "utterance_id": "u001"
      },
      "reaction": {
        "kind": "hmm",
        "intensity": "moderate"
      },
      "timestamps": {
        "start": "00:18.500",
